{
  "name": "54agent-paymenthub-core",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc",
    "dev": "NODE_ENV=development nodemon --exec ts-node src/index.ts",
    "start": "node dist/index.js",
    "start:dapr:dev": "dapr run --app-port ${APP_PORT:-3001} --dapr-http-port ${DAPR_HTTP_PORT:-3501} --config ./dapr/config.yaml --app-id 54agent-paymenthub-core --resources-path ./dapr/components -- npm run dev",
    "test": "export NODE_ENV=test && jest",
    "seed": "ts-node ./src/database/seeder.ts",
    "typeorm": "npx typeorm-ts-node-commonjs --dataSource ./src/database/dataSource.ts",
    "typeorm:migrate": "npm run typeorm -- migration:run",
    "typeorm:generate": "npm run typeorm -- migration:generate ./src/database/migrations/Migration",
    "typeorm:revert": "npm run typeorm -- migration:revert",
    "dapr:dev": "dapr run --app-port ${APP_PORT:-3001} --app-id 54agent-paymenthub-core --app-protocol http --dapr-http-port ${DAPR_HTTP_PORT:-3501} --config ./dapr/config.yaml -- npm run dev"
  },
  "devDependencies": {
    "@types/express": "^4",
    "@types/morgan": "^1",
    "@types/node": "^22.10.2",
    "@types/pg": "^8",
    "nodemon": "^3.1.4",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@dapr/dapr": "^3.4.0",
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "http-status": "^1.7.4",
    "logform": "^2.6.1",
    "morgan": "^1.10.0",
    "p-limit": "^6.2.0",
    "pg": "^8.12.0",
    "prom-client": "^15.1.3",
    "typeorm": "^0.3.20",
    "uuidv4": "^6.2.13",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  }
}
