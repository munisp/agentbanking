// Permify Authorization Schema for 54Link Agent Banking Platform
// Defines the relationship-based access control (ReBAC) model.

entity user {}

entity organization {
    relation admin @user
    relation member @user

    permission manage = admin
    permission view = admin or member
}

entity agent {
    relation owner @user
    relation supervisor @user
    relation organization @organization

    permission manage = owner or supervisor or organization.admin
    permission view_transactions = owner or supervisor or organization.member
    permission perform_cash_in = owner
    permission perform_cash_out = owner
    permission perform_transfer = owner
    permission view_float = owner or supervisor
    permission manage_settlement = supervisor or organization.admin
}

entity terminal {
    relation assigned_agent @agent
    relation fleet_manager @user
    relation organization @organization

    permission operate = assigned_agent.owner
    permission manage = fleet_manager or organization.admin
    permission view_status = assigned_agent.owner or fleet_manager or organization.admin
    permission remote_command = fleet_manager or organization.admin
    permission firmware_update = organization.admin
}

entity transaction {
    relation initiator @agent
    relation approver @user
    relation organization @organization

    permission view = initiator.owner or initiator.supervisor or approver or organization.admin
    permission approve = approver or organization.admin
    permission reverse = organization.admin
    permission dispute = initiator.owner
}

entity settlement_batch {
    relation agent @agent
    relation processor @user
    relation organization @organization

    permission view = agent.owner or agent.supervisor or processor or organization.admin
    permission process = processor or organization.admin
    permission reconcile = organization.admin
}

entity kyc_record {
    relation subject @user
    relation reviewer @user
    relation organization @organization

    permission view = subject or reviewer or organization.admin
    permission approve = reviewer or organization.admin
    permission reject = reviewer or organization.admin
}

entity float_account {
    relation agent @agent
    relation treasury @user
    relation organization @organization

    permission view_balance = agent.owner or agent.supervisor or treasury or organization.admin
    permission top_up = treasury or organization.admin
    permission debit = agent.owner
}

entity report {
    relation owner @user
    relation organization @organization

    permission view = owner or organization.admin or organization.member
    permission export = owner or organization.admin
    permission delete = organization.admin
}
