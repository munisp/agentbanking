{
  "name": "54Link POS Shell — NiFi Data Flow",
  "description": "Production data flow for Nigerian agency banking platform",
  "version": "1.0.0",
  "processGroups": [
    {
      "name": "Transaction Ingestion",
      "description": "Real-time transaction data ingestion from POS terminals",
      "processors": [
        { "type": "ListenHTTP", "name": "POS Terminal Webhook", "config": { "port": 9090, "path": "/api/transactions" } },
        { "type": "ValidateRecord", "name": "Schema Validation", "config": { "schema": "transaction-schema", "validationStrategy": "strict" } },
        { "type": "RouteOnAttribute", "name": "Route by Type", "config": { "routes": { "cash_withdrawal": "${transaction.type:equals('cash_withdrawal')}", "transfer": "${transaction.type:equals('transfer')}", "bill_payment": "${transaction.type:equals('bill_payment')}" } } },
        { "type": "PublishKafka", "name": "Kafka Producer", "config": { "brokers": "kafka:9092", "topic": "pos.transaction.created" } }
      ]
    },
    {
      "name": "Fraud Detection Pipeline",
      "description": "Real-time fraud scoring and alert generation",
      "processors": [
        { "type": "ConsumeKafka", "name": "Transaction Consumer", "config": { "brokers": "kafka:9092", "topic": "pos.transaction.created", "groupId": "fraud-detection" } },
        { "type": "InvokeHTTP", "name": "ML Fraud Scoring", "config": { "url": "http://app:3000/api/trpc/mlScoring.scoreTransaction", "method": "POST" } },
        { "type": "RouteOnAttribute", "name": "Risk Router", "config": { "routes": { "high_risk": "${fraud.score:gt(70)}", "medium_risk": "${fraud.score:gt(40)}", "low_risk": "${fraud.score:le(40)}" } } },
        { "type": "PutDatabaseRecord", "name": "Store Alert", "config": { "database": "postgresql://postgres:5432/posshell", "table": "fraud_alerts" } }
      ]
    },
    {
      "name": "Qdrant Vector Sync",
      "description": "Sync transaction embeddings to Qdrant for similarity search",
      "processors": [
        { "type": "ConsumeKafka", "name": "Embedding Consumer", "config": { "brokers": "kafka:9092", "topic": "pos.transaction.completed", "groupId": "qdrant-sync" } },
        { "type": "InvokeHTTP", "name": "Generate Embedding", "config": { "url": "http://app:3000/api/trpc/qdrantVectorSearch.upsertDocument", "method": "POST" } },
        { "type": "InvokeHTTP", "name": "Upsert to Qdrant", "config": { "url": "http://qdrant:6333/collections/transactions/points", "method": "PUT" } }
      ]
    },
    {
      "name": "FalkorDB Graph Sync",
      "description": "Update graph relationships for agent-transaction network",
      "processors": [
        { "type": "ConsumeKafka", "name": "Graph Consumer", "config": { "brokers": "kafka:9092", "topic": "pos.transaction.completed", "groupId": "falkordb-sync" } },
        { "type": "ExecuteScript", "name": "Build Cypher Query", "config": { "language": "python", "script": "MERGE (a:Agent {id: $agentId}) MERGE (t:Transaction {id: $txnId}) CREATE (a)-[:PROCESSED]->(t)" } },
        { "type": "InvokeHTTP", "name": "Execute Cypher", "config": { "url": "http://falkordb:6379", "method": "POST" } }
      ]
    },
    {
      "name": "Lakehouse Data Export",
      "description": "Daily batch export to Delta Lake format",
      "processors": [
        { "type": "QueryDatabaseTable", "name": "Extract Daily Data", "config": { "database": "postgresql://postgres:5432/posshell", "query": "SELECT * FROM transactions WHERE created_at >= CURRENT_DATE - INTERVAL '1 day'" } },
        { "type": "ConvertRecord", "name": "Convert to Parquet", "config": { "format": "parquet", "compression": "snappy" } },
        { "type": "PutS3Object", "name": "Write to Lakehouse", "config": { "bucket": "54link-lakehouse", "prefix": "bronze/transactions/", "partitionBy": "date" } }
      ]
    },
    {
      "name": "CBN Compliance Reporting",
      "description": "Automated regulatory report generation for CBN",
      "processors": [
        { "type": "ExecuteSQL", "name": "Query Compliance Data", "config": { "query": "SELECT * FROM compliance_audit_log WHERE report_date = CURRENT_DATE" } },
        { "type": "ConvertRecord", "name": "Format CBN Report", "config": { "format": "csv", "schema": "cbn-transaction-report-v2" } },
        { "type": "PutSFTP", "name": "Submit to CBN", "config": { "host": "sftp.cbn.gov.ng", "port": 22, "directory": "/reports/daily" } }
      ]
    }
  ],
  "controllerServices": [
    { "type": "DBCPConnectionPool", "name": "PostgreSQL Pool", "config": { "url": "jdbc:postgresql://postgres:5432/posshell", "driver": "org.postgresql.Driver" } },
    { "type": "JsonTreeReader", "name": "JSON Reader", "config": { "schema": "infer" } },
    { "type": "JsonRecordSetWriter", "name": "JSON Writer", "config": {} },
    { "type": "AvroRecordSetWriter", "name": "Avro Writer", "config": {} }
  ]
}
