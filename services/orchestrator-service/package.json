{
  "name": "orchestrator-service",
  "version": "0.0.1",
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development nodemon",
    "lint": "eslint . --ext .ts",
    "clean": "rimraf dist",
    "build": "tsc",
    "start": "NODE_ENV=production node dist/index.js",
    "start:dapr:dev": "dapr run --app-port 8006 --dapr-http-port 3500 --app-id 54_link_orchestrator_service --resources-path ./dapr/components -- npm run dev",
    "typeorm": "npx typeorm-ts-node-commonjs --dataSource ./src/database/dataSource.ts",
    "typeorm:entity:create": "./node_modules/.bin/ts-node ./node_modules/.bin/typeorm entity:create ./src/entity",
    "typeorm:migrate": "npm run typeorm -- migration:run",
    "typeorm:generate": "npm run typeorm -- migration:generate ./src/database/migrations/migration",
    "typeorm:revert": "npm run typeorm -- migration:revert",
    "test": "NODE_ENV=test jest"
  },
  "dependencies": {
    "@dapr/dapr": "^3.6.1",
    "@temporalio/activity": "^1.13.2",
    "@temporalio/client": "^1.13.2",
    "@temporalio/common": "^1.13.2",
    "@temporalio/worker": "^1.13.2",
    "@temporalio/workflow": "^1.13.2",
    "axios": "^1.13.2",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "http-status": "1.7.4",
    "https": "^1.0.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.5",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "typescript": "^5.4.4",
    "typescript-eslint": "^8.31.1",
    "winston": "^3.13.0",
    "yamljs": "^0.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-useragent": "^1.0.5",
    "@types/morgan": "^1.9.9",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/yamljs": "^0.2.34",
    "esbuild": "^0.25.3",
    "esbuild-register": "^3.6.0",
    "eslint": "^9.25.1",
    "nodemon": "^3.1.0",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2"
  }
}
