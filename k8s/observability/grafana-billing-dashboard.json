{
  "annotations": { "list": [] },
  "description": "54Link POS Shell — Billing Engine Observability Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Billing Transaction Rate (TPS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(pos_shell_billing_transactions_total[5m])",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ops"
        }
      }
    },
    {
      "title": "Revenue by Tenant (24h)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (tenant_id) (increase(pos_shell_billing_revenue_total[24h]))",
          "legendFormat": "Tenant {{tenant_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyNGN",
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 100000 },
              { "color": "green", "value": 500000 }
            ]
          }
        }
      }
    },
    {
      "title": "Invoice Processing Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(pos_shell_invoice_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(pos_shell_invoice_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "title": "Billing Error Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(pos_shell_billing_errors_total[5m])) / sum(rate(pos_shell_billing_transactions_total[5m])) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "Dunning Workflow Status",
      "type": "piechart",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "sum by (status) (pos_shell_dunning_workflows)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "TigerBeetle Account Balances",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "pos_shell_tigerbeetle_account_balance",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Kafka Billing Topic Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (topic) (kafka_consumer_group_lag{group=~\"billing-.*\"})",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          }
        }
      }
    },
    {
      "title": "Temporal Workflow Execution",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(temporal_workflow_completed_total{namespace=\"billing\"}[5m])",
          "legendFormat": "completed",
          "refId": "A"
        },
        {
          "expr": "rate(temporal_workflow_failed_total{namespace=\"billing\"}[5m])",
          "legendFormat": "failed",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Reconciliation Discrepancies",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "pos_shell_reconciliation_discrepancies_total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Stripe Webhook Processing",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 24 },
      "targets": [
        {
          "expr": "rate(pos_shell_stripe_webhook_processed_total[5m])",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Monthly Invoice Generation",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "pos_shell_monthly_invoices_generated_total",
          "refId": "A"
        }
      ]
    },
    {
      "title": "RBAC Permission Denials",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 24 },
      "targets": [
        {
          "expr": "sum(rate(pos_shell_rbac_denied_total[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["billing", "54link", "pos-shell"],
  "templating": {
    "list": [
      {
        "name": "tenant_id",
        "type": "query",
        "query": "label_values(pos_shell_billing_transactions_total, tenant_id)",
        "refresh": 2
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "54Link Billing Engine Dashboard",
  "uid": "54link-billing-engine"
}
