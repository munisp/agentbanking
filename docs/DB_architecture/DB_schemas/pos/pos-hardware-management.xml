<mxfile host="app.diagrams.net">
  <diagram name="POS Hardware Service DB Architecture">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- =========================
             DEVICE CORE TABLE
        ========================== -->
        <mxCell id="pos_device" value="POSDevice&#xa;----------------------&#xa;id (PK)&#xa;device_id&#xa;device_name&#xa;device_type&#xa;device_status&#xa;manufacturer&#xa;model&#xa;serial_number&#xa;assigned_agent_id&#xa;location&#xa;connectivity_type&#xa;lat/lng&#xa;status metrics" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="420" y="40" width="280" height="260" as="geometry"/>
        </mxCell>

        <!-- =========================
             CATALOG
        ========================== -->
        <mxCell id="catalog_manufacturer" value="CatalogManufacturer&#xa;----------------------&#xa;id (PK)&#xa;name&#xa;slug&#xa;logo_url&#xa;website" style="shape=rectangle;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="260" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="catalog_model" value="CatalogModel&#xa;----------------------&#xa;id (PK)&#xa;manufacturer_id (FK)&#xa;name&#xa;slug&#xa;mdm_model_id&#xa;apk_variant&#xa;device_type" style="shape=rectangle;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="40" y="230" width="260" height="180" as="geometry"/>
        </mxCell>

        <!-- =========================
             TELEMETRY
        ========================== -->
        <mxCell id="telemetry" value="DeviceTelemetry&#xa;----------------------&#xa;id (PK)&#xa;device_id (FK)&#xa;timestamp&#xa;cpu/memory/disk&#xa;network usage&#xa;temp/battery&#xa;errors/tx count" style="shape=rectangle;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="760" y="40" width="280" height="200" as="geometry"/>
        </mxCell>

        <!-- =========================
             ALERTS
        ========================== -->
        <mxCell id="alerts" value="DeviceAlert&#xa;----------------------&#xa;id (PK)&#xa;device_id (FK)&#xa;alert_type&#xa;severity&#xa;status&#xa;ack/resolved&#xa;threshold/actual" style="shape=rectangle;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="760" y="270" width="280" height="200" as="geometry"/>
        </mxCell>

        <!-- =========================
             EDGE COMPUTING
        ========================== -->
        <mxCell id="edge_node" value="EdgeComputingNode&#xa;----------------------&#xa;id (PK)&#xa;node_id&#xa;cpu/ram/storage&#xa;gpu enabled&#xa;location&#xa;health score&#xa;services" style="shape=rectangle;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="420" y="340" width="280" height="200" as="geometry"/>
        </mxCell>

        <!-- =========================
             IOT DEVICES
        ========================== -->
        <mxCell id="iot_device" value="IoTDevice&#xa;----------------------&#xa;id (PK)&#xa;device_id&#xa;type&#xa;edge_node_id (FK)&#xa;protocol&#xa;status&#xa;battery/signal&#xa;mqtt topic" style="shape=rectangle;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="40" y="450" width="260" height="200" as="geometry"/>
        </mxCell>

        <!-- =========================
             CONFIG PROFILE
        ========================== -->
        <mxCell id="config_profile" value="DeviceConfigurationProfile&#xa;----------------------&#xa;id (PK)&#xa;device_type&#xa;config JSON&#xa;security policy&#xa;network config&#xa;auto update" style="shape=rectangle;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="760" y="500" width="280" height="180" as="geometry"/>
        </mxCell>

        <!-- =========================
             RELATIONSHIPS
        ========================== -->

        <!-- Manufacturer -> Model -->
        <mxCell id="e1" edge="1" parent="1" source="catalog_manufacturer" target="catalog_model" style="endArrow=block;strokeColor=#82b366;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Manufacturer -> POSDevice -->
        <mxCell id="e2" edge="1" parent="1" source="catalog_manufacturer" target="pos_device" style="endArrow=block;strokeColor=#6c8ebf;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- POSDevice -> Telemetry -->
        <mxCell id="e3" edge="1" parent="1" source="pos_device" target="telemetry" style="endArrow=block;strokeColor=#d6b656;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- POSDevice -> Alerts -->
        <mxCell id="e4" edge="1" parent="1" source="pos_device" target="alerts" style="endArrow=block;strokeColor=#b85450;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- POSDevice -> Edge Node -->
        <mxCell id="e5" edge="1" parent="1" source="pos_device" target="edge_node" style="endArrow=block;strokeColor=#9673a6;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edge Node -> IoT Device -->
        <mxCell id="e6" edge="1" parent="1" source="edge_node" target="iot_device" style="endArrow=block;strokeColor=#d79b00;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Device -> Config Profile (logical mapping) -->
        <mxCell id="e7" edge="1" parent="1" source="pos_device" target="config_profile" style="endArrow=block;dashed=1;strokeColor=#666666;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>