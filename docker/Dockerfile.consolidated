FROM ubuntu:22.04 AS base

ARG SERVICES
ARG PRIMARY_LANG=python
ARG PORT_BASE=9100

ENV DEBIAN_FRONTEND=noninteractive
ENV SERVICES=${SERVICES}
ENV PORT_BASE=${PORT_BASE}
ENV PRIMARY_LANG=${PRIMARY_LANG}

# ── Runtimes ────────────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 python3-pip python3.11-dev python3.11-venv \
    curl wget ca-certificates git \
    libpq-dev gcc g++ make \
    supervisor \
    && rm -rf /var/lib/apt/lists/*

# Python default
RUN ln -sf /usr/bin/python3.11 /usr/bin/python3 && ln -sf /usr/bin/python3 /usr/bin/python
RUN pip install --no-cache-dir uvicorn[standard]

# Go — copy from official image to avoid network-dependent downloads
COPY --from=golang:1.23.4 /usr/local/go /usr/local/go
ENV PATH="/usr/local/go/bin:$PATH"
ENV GOPATH="/root/go"

# Node 20
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# pnpm (for projects that use pnpm as package manager)
RUN npm install -g pnpm@10

# ── Source code ──────────────────────────────────────────────────────────────
WORKDIR /app
COPY ["services/", "/app/services/"]

# Flatten services nested under sub-group directories so entrypoint.sh can
# find them by flat name (e.g. transaction-services/transaction-ledger → transaction-ledger)
RUN find /app/services -maxdepth 2 -mindepth 2 -type d | while read d; do \
      name=$(basename "$d"); \
      [ ! -d "/app/services/$name" ] && cp -r "$d" "/app/services/$name" || true; \
    done

RUN mkdir -p /app/bin /var/log/supervisor /etc/supervisor/conf.d

# ── Build all services in this group ─────────────────────────────────────────
COPY docker/build-services.sh /docker/build-services.sh
RUN chmod +x /docker/build-services.sh && /docker/build-services.sh

# ── Supervisor base config ───────────────────────────────────────────────────
COPY docker/supervisord.conf /etc/supervisor/supervisord.conf

# ── Entrypoint: generates per-service supervisor programs and starts supervisord
COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
