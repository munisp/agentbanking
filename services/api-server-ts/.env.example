# ═══════════════════════════════════════════════════════════════════════════════
# AgentBanking API Server — Production Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in all CHANGE_ME values before deploying.
# Never commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
VITE_APP_ID=agentbanking-production

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://agentbanking:CHANGE_ME_STRONG_PASSWORD_32CHARS@postgres:5432/agentbanking
POSTGRES_DB=agentbanking
POSTGRES_USER=agentbanking
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32CHARS
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD_24CHARS@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_24CHARS

# ── JWT / Auth ────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_JWT_SECRET_64CHARS_MINIMUM_FOR_HS512_ALGORITHM_SECURITY
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Keycloak (Identity Provider) ─────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=agentbanking
KEYCLOAK_CLIENT_ID=api-server
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_KEYCLOAK_CLIENT_SECRET
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK_ADMIN_PASSWORD

# ── TigerBeetle (Financial Ledger) ───────────────────────────────────────────
TIGERBEETLE_ADDRESS=tigerbeetle:3000
TIGERBEETLE_CLUSTER_ID=0

# ── Temporal (Workflow Orchestration) ────────────────────────────────────────
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=agentbanking-tasks

# ── Permify (Authorization) ───────────────────────────────────────────────────
PERMIFY_URL=http://permify:3476
PERMIFY_TENANT_ID=t1

# ── Dapr (Service Mesh / Pub-Sub) ────────────────────────────────────────────
DAPR_HTTP_PORT=3500
DAPR_GRPC_PORT=50001
DAPR_APP_ID=api-server
DAPR_PUBSUB_NAME=agentbanking-pubsub
DAPR_STATE_STORE_NAME=agentbanking-statestore

# ── Fluvio (Event Streaming) ──────────────────────────────────────────────────
FLUVIO_GATEWAY_URL=http://fluvio-gateway:9090
FLUVIO_TOPIC_TRANSACTIONS=transactions
FLUVIO_TOPIC_EVENTS=events
FLUVIO_TOPIC_AUDIT=audit

# ── APISIX (API Gateway) ──────────────────────────────────────────────────────
APISIX_ADMIN_URL=http://apisix:9180
APISIX_ADMIN_KEY=CHANGE_ME_APISIX_ADMIN_KEY_32CHARS
APISIX_GATEWAY_URL=http://apisix:9080

# ── OpenAppSec (WAF) ──────────────────────────────────────────────────────────
OPENAPPSEC_AGENT_URL=http://openappsec-agent:8080
OPENAPPSEC_MODE=prevent

# ── MinIO / S3 (Object Storage) ──────────────────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
S3_BUCKET=agentbanking
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET_KEY
AWS_REGION=us-east-1

# ── AI / LLM (OpenAI-compatible) ─────────────────────────────────────────────
# Works with OpenAI, Azure OpenAI, Ollama, LocalAI, or any OpenAI-compatible API.
# Set OPENAI_API_BASE to override the endpoint (e.g. http://ollama:11434/v1 for local).
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
IMAGE_GEN_MODEL=dall-e-3

# ── Data API (External Data Source) ──────────────────────────────────────────
DATA_API_BASE_URL=https://data.agentbanking.internal/api
DATA_API_KEY=CHANGE_ME_DATA_API_KEY

# ── Heartbeat / Health Check ──────────────────────────────────────────────────
HEARTBEAT_API_URL=https://health.agentbanking.internal/heartbeat
HEARTBEAT_API_KEY=CHANGE_ME_HEARTBEAT_API_KEY

# ── Maps / Geocoding ──────────────────────────────────────────────────────────
# Uses Google Maps API or Nominatim (open-source, no key needed).
# Set MAPS_API_BASE_URL to https://nominatim.openstreetmap.org for free geocoding.
MAPS_API_BASE_URL=https://maps.googleapis.com/maps/api
GOOGLE_MAPS_API_KEY=CHANGE_ME_GOOGLE_MAPS_API_KEY

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.agentbanking.internal
SMTP_PORT=587
SMTP_USER=noreply@agentbanking.ng
SMTP_PASS=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=AgentBanking <noreply@agentbanking.ng>
SMTP_SECURE=true

# ── SMS / OTP ─────────────────────────────────────────────────────────────────
SMS_PROVIDER=termii
TERMII_API_KEY=CHANGE_ME_TERMII_API_KEY
TERMII_SENDER_ID=AgentBank

# ── FIDO2 / WebAuthn ─────────────────────────────────────────────────────────
FIDO2_RP_ID=agentbanking.ng
FIDO2_RP_NAME=AgentBanking
FIDO2_ORIGIN=https://agentbanking.ng

# ── HashiCorp Vault (Secrets Management) ─────────────────────────────────────
VAULT_URL=http://vault:8200
VAULT_TOKEN=CHANGE_ME_VAULT_ROOT_TOKEN
VAULT_APP_TOKEN=CHANGE_ME_VAULT_APP_TOKEN

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_URL=http://grafana:3000
PROMETHEUS_URL=http://prometheus:9090
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# ── CBN / Regulatory Reporting ───────────────────────────────────────────────
CBN_API_URL=https://api.cbn.gov.ng
CBN_API_KEY=CHANGE_ME_CBN_API_KEY
CBN_INSTITUTION_CODE=CHANGE_ME_CBN_INSTITUTION_CODE

# ── NIBSS / NIP ───────────────────────────────────────────────────────────────
NIBSS_API_URL=https://api.nibss-plc.com.ng
NIBSS_API_KEY=CHANGE_ME_NIBSS_API_KEY
NIBSS_INSTITUTION_CODE=CHANGE_ME_NIBSS_INSTITUTION_CODE

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=agentbanking.ng
CORS_ORIGINS=https://agentbanking.ng,https://admin.agentbanking.ng

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_BNPL=true
ENABLE_LOAN_ORIGINATION=true
ENABLE_AGENT_GAMIFICATION=true
ENABLE_AML_SCREENING=true
ENABLE_LAKEHOUSE_SYNC=true
ENABLE_REAL_TIME_ALERTS=true

# ── Caddy Edge Proxy ──────────────────────────────────────────────────────────
# URL of the Caddy Admin API (used by caddyWebhook.ts for cert pre-warming)
CADDY_ADMIN_URL=http://caddy:2019
# Internal URL of this app (used for cache-bust self-calls from caddyWebhook)
APP_INTERNAL_URL=http://app:3000
