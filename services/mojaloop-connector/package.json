{
  "name": "54agent-paymenthub-connector-mojaloop",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc",
    "dev": "NODE_ENV=development nodemon --exec ts-node src/index.ts",
    "start": "npm run build && node dist/index.js",
    "test": "export NODE_ENV=test && jest",
    "seed": "ts-node ./src/database/seeder.ts",
    "typeorm": "npx typeorm-ts-node-commonjs --dataSource ./src/database/dataSource.ts",
    "typeorm:migrate": "npm run typeorm -- migration:run",
    "typeorm:generate": "npm run typeorm -- migration:generate ./src/database/migrations/MessageSvcMigration",
    "typeorm:revert": "npm run typeorm -- migration:revert",
    "dapr:dev": "dapr run --app-port 3001 --app-id 54agent-paymenthub-mojaloop-connector --app-protocol http --dapr-http-port 3501 -- npm run dev"
  },
  "devDependencies": {
    "@types/express": "^4",
    "@types/morgan": "^1",
    "@types/node": "^22.10.2",
    "@types/pg": "^8",
    "nodemon": "^3.1.4",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@dapr/dapr": "^3.4.0",
    "@temporalio/activity": "^1.11.5",
    "@temporalio/client": "^1.11.5",
    "@temporalio/worker": "^1.11.5",
    "@temporalio/workflow": "^1.11.5",
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "decimal.js": "^10.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "http-status": "^1.7.4",
    "ilp-packet": "^3.1.4-alpha.2",
    "ioredis": "^5.4.2",
    "logform": "^2.6.1",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "typeorm": "^0.3.20",
    "uuid": "^11.0.3",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  }
}
